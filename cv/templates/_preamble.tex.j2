%% ============================================================
%% SHARED PREAMBLE — the "old-money" aesthetic.
%% Both the one-page and full CV \input this, so fonts, colours,
%% and section commands stay identical across the two layouts.
%% Compile with XeLaTeX (or LuaLaTeX) + biber.
%% ============================================================

\usepackage[utf8]{inputenc}
\usepackage{enumitem}
\usepackage{xcolor}
\usepackage{hyperref}
\usepackage{tikz}
\usepackage{fontspec}
\usepackage{calc}
\usepackage{graphicx}
\usepackage{xparse}

%% ----- Colour palette (generated from theme/theme.yaml) -----
\VAR{color_defs}

%% ----- Font pairing (families + face suffixes from the active theme) -----
%% Body + heading families and their per-theme weight suffixes are injected,
%% so any font pair (serif display / sans display) can be themed without edits.
\setmainfont{\VAR{font_text}}[
    Path=\VAR{fonts_path}/,
    Extension=.ttf,
    UprightFont=*-\VAR{face_text_upright},
    BoldFont=*-\VAR{face_text_bold},
    ItalicFont=*-\VAR{face_text_italic}
]
\newfontfamily\headerfont{\VAR{font_display}}[
    Path=\VAR{fonts_path}/,
    Extension=.ttf,
    UprightFont=*-\VAR{face_display_upright},
    BoldFont=*-\VAR{face_display_bold},
    LetterSpace=\VAR{display_letterspace}
]
\newfontfamily\titlefont{\VAR{font_display}}[
    Path=\VAR{fonts_path}/,
    Extension=.ttf,
    UprightFont=*-\VAR{face_display_title},
    BoldFont=*-\VAR{face_display_title_bold}
]
\newfontfamily\mediumfont{\VAR{font_text}}[
    Path=\VAR{fonts_path}/,
    Extension=.ttf,
    UprightFont=*-\VAR{face_text_medium},
    BoldFont=*-\VAR{face_text_medium_bold}
]

\pagestyle{empty}
\hypersetup{colorlinks=true, linkcolor=navy, urlcolor=gold}

%% ----- Section title commands (gold rule under a display-font heading) -----
\newlength{\sectionunderlinegap}\setlength{\sectionunderlinegap}{4pt}
\newlength{\sectionbottomspacing}\setlength{\sectionbottomspacing}{10pt}
\newcommand{\sectionrule}{{\color{gold}\rule{\linewidth}{1pt}}}

\newcommand{\leftsection}[1]{%
  {\headerfont\Large\color{gold} #1\par}%
  \vspace{\sectionunderlinegap}\sectionrule\vspace{\sectionbottomspacing}}

\newcommand{\rightsection}[1]{%
  {\headerfont\Large\color{navy} #1\par}%
  \vspace{\sectionunderlinegap}\sectionrule\vspace{\sectionbottomspacing}}

%% ----- Entry commands -----
% Sidebar contact line: gold label over a white value. Links inside the value
% are forced white (via \href color hooks) so they stay readable on navy.
\NewDocumentCommand{\contactentry}{m m}{%
  {\mediumfont\color{gold} #1}\\%
  {\small\color{sidebartext}\hypersetup{urlcolor=sidebartext}#2}\vspace{10pt}}

% Sidebar skill line: white label + a gold dot-rating (0–5).
\NewDocumentCommand{\skillentry}{m m}{%
  {\small\color{sidebartext} #1}\\[1pt]%
  {\footnotesize\color{gold}%
    \ifnum#2>0\textbullet\fi\ifnum#2>1\,\textbullet\fi\ifnum#2>2\,\textbullet\fi%
    \ifnum#2>3\,\textbullet\fi\ifnum#2>4\,\textbullet\fi}\vspace{8pt}}

% Sidebar plain tag line (e.g. a research-interest title).
\NewDocumentCommand{\tagentry}{m}{%
  {\small\color{sidebartext} #1}\\[5pt]}

% Right-column entry: title [right-aligned date] [subtitle] {body}.
% Each entry is its own \par-terminated block so spacing between entries is
% governed solely by the trailing \vspace, whether or not a body is present.
\NewDocumentCommand{\rightentry}{m o o m}{%
  \par\noindent
  {\mediumfont\normalsize\color{charcoal}#1}%
  \IfValueT{#2}{\hfill{\color{warmgray}\small\textit{#2}}}\par
  \IfValueT{#3}{\nopagebreak\vspace{2pt}{\small\color{warmgray}\textit{#3}}\par}%
  \if\relax\detokenize{#4}\relax\else\nopagebreak\vspace{6pt}\par{\color{charcoal}#4}\par\fi
  \vspace{11pt}}

\newenvironment{rightitemize}{%
  \begin{itemize}[leftmargin=*, nosep, after=\vspace{6pt}, itemsep=4pt]}{%
  \end{itemize}}
