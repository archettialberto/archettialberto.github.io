%% ONE-PAGE CV — condensed, two-column (navy sidebar + content).
%% Driven entirely by data; edit data/*.yaml, not this file.
%% Sidebar: contact (icon lines), headline numbers, skills.
%% Content: profile, experience, selected publications, education, awards.
\documentclass[10pt,a4paper]{article}
\usepackage[margin=0in]{geometry}
\input{_preamble.tex}
\usepackage{fontawesome5}

%% Layout lengths
\newlength{\contentleftpadding}\setlength{\contentleftpadding}{0.5in}
\newlength{\contentwidth}\setlength{\contentwidth}{\paperwidth-2\contentleftpadding}
\newlength{\leftcolwidth}\setlength{\leftcolwidth}{0.28\contentwidth}
\newlength{\colgap}\setlength{\colgap}{0.04\contentwidth}
\newlength{\rightcolwidth}\setlength{\rightcolwidth}{0.68\contentwidth}
\newlength{\sidebarwidth}\setlength{\sidebarwidth}{\contentleftpadding+\leftcolwidth}
\newlength{\headerheight}\setlength{\headerheight}{2.2cm}

%% One-pager runs tighter than the preamble defaults so the extra
%% Selected Publications section still fits a single A4 page.
\setlength{\sectionunderlinegap}{3pt}
\setlength{\sectionbottomspacing}{7pt}
\RenewDocumentCommand{\rightentry}{m o o m}{%
  \par\noindent
  {\mediumfont\normalsize\color{charcoal}#1}%
  \IfValueT{#2}{\hfill{\color{warmgray}\small\textit{#2}}}\par
  \IfValueT{#3}{\nopagebreak\vspace{1pt}{\small\color{warmgray}\textit{#3}}\par}%
  \if\relax\detokenize{#4}\relax\else\nopagebreak\vspace{4pt}\par{\color{charcoal}#4}\par\fi
  \vspace{6pt}}

%% Compact publication row: small title + right-aligned year, venue beneath.
\NewDocumentCommand{\pubentry}{m m m}{%
  \par\noindent{\mediumfont\small\color{charcoal}#1}\hfill{\color{warmgray}\small\textit{#3}}\par
  \if\relax\detokenize{#2}\relax\else\nopagebreak\vspace{1pt}{\footnotesize\color{warmgray}#2}\par\fi
  \vspace{4pt}}

%% Sidebar contact line: gold icon (fixed-width box so values align) + value.
\NewDocumentCommand{\contactline}{m m}{%
  \par\noindent\makebox[1.15em][c]{\small\color{gold}#1}\hspace{0.45em}%
  {\footnotesize\color{sidebartext}\hypersetup{urlcolor=sidebartext}#2}\par\vspace{7pt}}

%% Sidebar headline number: large display digit over a small tracked label.
\NewDocumentCommand{\statentry}{m m}{%
  \par\noindent{\titlefont\fontsize{19}{21}\selectfont\color{gold}#1}\\[2pt]%
  {\scriptsize\color{sidebartext}\addfontfeatures{LetterSpace=6.0}\MakeUppercase{#2}}\par\vspace{10pt}}

#= FontAwesome icon per contact `icon` hint (matches the website's icon set). =#
\BLOCK{set icons = {'email': '\\faEnvelope', 'github': '\\faGithub', 'linkedin': '\\faLinkedinIn', 'scholar': '\\faGraduationCap', 'instagram': '\\faInstagram'} }

\begin{document}
% Navy sidebar background: a full-height band anchored to the page, drawn once.
\begin{tikzpicture}[remember picture,overlay]
  \fill[navy] (current page.north west) rectangle ([xshift=\sidebarwidth]current page.south west);
\end{tikzpicture}

\noindent\hspace{\contentleftpadding}\begin{minipage}[t]{\contentwidth}
\vspace*{0pt}

% --- Header band: logo + name/title ---
\noindent
\begin{minipage}[t][\headerheight][t]{\leftcolwidth}
  \vspace*{-26pt}
  \begin{minipage}[t][\headerheight][t]{\leftcolwidth - \colgap}
    \vspace*{0pt}\begin{flushright}\includegraphics[height=2.2cm]{\VAR{logo}}\end{flushright}
  \end{minipage}
\end{minipage}\hspace{\colgap}\begin{minipage}[t][\headerheight][t]{\rightcolwidth}
  \vspace*{0pt}
  {\titlefont\fontsize{32}{38}\selectfont\color{navy} \VAR{profile.full_name | tex}}\\[5pt]
  {\fontsize{11}{14}\selectfont\color{warmgray}\addfontfeatures{LetterSpace=8.0}\MakeUppercase{\VAR{profile.title | tex}}}
\end{minipage}
\vspace{0.5em}

% --- Two columns ---
\noindent
\begin{minipage}[t]{\leftcolwidth}\vspace*{0pt}
  \begin{minipage}[t]{\leftcolwidth - \colgap}\vspace*{0pt}\raggedright

    \leftsection{Contact}
    \BLOCK{for c in profile.contacts | selectattr('cv')}\contactline{\BLOCK{if c.icon and c.icon in icons}\VAR{icons[c.icon]}\BLOCK{endif}}{%
      \BLOCK{set label = 'Google Scholar' if c.icon == 'scholar' else (c.value | tex)}\BLOCK{if c.url}\href{\VAR{c.url}}{\VAR{label}}\BLOCK{else}\VAR{label}\BLOCK{endif}}
    \BLOCK{endfor}

    \BLOCK{if stats}\vspace{8pt}\leftsection{Highlights}
    \BLOCK{if stats.publications}\statentry{\VAR{stats.publications}}{Publications}\BLOCK{endif}
    \BLOCK{if stats.citations}\statentry{\VAR{stats.citations}}{Citations}\BLOCK{endif}
    \BLOCK{if stats.h_index}\statentry{\VAR{stats.h_index}}{h-index}\BLOCK{endif}
    \BLOCK{if stats.teaching_hours}\statentry{\VAR{stats.teaching_hours}}{Teaching hours}\BLOCK{endif}
    \BLOCK{if stats.students}\statentry{\VAR{stats.students}}{Students supervised}\BLOCK{endif}
    \BLOCK{endif}

    \BLOCK{if skills}\vspace{2pt}\leftsection{Skills}
    \BLOCK{for g in skills}{\footnotesize\color{gold}\addfontfeatures{LetterSpace=5.0}\MakeUppercase{\VAR{g.category | tex}}}\\[2pt]
    {\small\color{sidebartext}\VAR{g.skills | join(', ') | tex}}\\[8pt]
    \BLOCK{endfor}\BLOCK{endif}
  \end{minipage}
\end{minipage}\hspace{\colgap}\begin{minipage}[t]{\rightcolwidth}\vspace*{0pt}

  \rightsection{Profile}
  {\color{charcoal}\VAR{profile.summary | tex}}
  \vspace{10pt}

  \rightsection{Experience}
  \BLOCK{for e in employment}\rightentry{\VAR{e.role | tex}, \VAR{e.org | tex}}[\VAR{e.period}]\BLOCK{if e.location}[\VAR{e.location | tex}]\BLOCK{endif}{\BLOCK{if e.details}\begin{rightitemize}\BLOCK{for d in e.details}\item \textit{\VAR{d.label | tex}} — \VAR{d.text | tex}
    \BLOCK{endfor}\end{rightitemize}\BLOCK{endif}}
  \BLOCK{endfor}

  \BLOCK{set sel = publications | selectattr('selected') | list}
  \BLOCK{if sel}\rightsection{Selected Publications}
  \BLOCK{for p in sel}\pubentry{\VAR{p.title | tex}}{\BLOCK{if p.venue}\VAR{p.venue | tex}\BLOCK{endif}}{\VAR{p.year}}
  \BLOCK{endfor}\BLOCK{endif}

  \rightsection{Education}
  \BLOCK{for e in education}\rightentry{\VAR{e.degree | tex}}[\VAR{e.period}][\VAR{e.org | tex}\BLOCK{if e.grade} — \VAR{e.grade | tex}\BLOCK{endif}]{}
  \BLOCK{endfor}

  \BLOCK{if awards}\rightsection{Awards}
  \BLOCK{for a in awards}\rightentry{\VAR{a.title | tex}}[\BLOCK{if a.year}\VAR{a.year}\BLOCK{endif}]\BLOCK{if a.org}[\VAR{a.org | tex}]\BLOCK{endif}{}
  \BLOCK{endfor}\BLOCK{endif}

\end{minipage}
\end{minipage}
\end{document}
